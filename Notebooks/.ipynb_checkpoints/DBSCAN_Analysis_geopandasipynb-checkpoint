   "source": [
    "# --- LÓGICA ESPACIAL ESTRICTA PARA LAS ZONAS ---\n",
    "# Determinamos físicamente las zonas cortando el ancho de la playa en 3 franjas\n",
    "x_max = gdf_utm['x_metros'].max() # Lo más al Este (Agua)\n",
    "x_min = gdf_utm['x_metros'].min() # Lo más al Oeste (Duna/Calle)\n",
    "ancho_playa = x_max - x_min\n",
    "limite_AB = x_max - (ancho_playa * 0.33)\n",
    "limite_BC = x_max - (ancho_playa * 0.66)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 51,
   "id": "82ebf361-0a4b-4f2c-be42-a80eafd3b951",
   "metadata": {},
   "outputs": [],
   "source": [
    "def asignar_zona_fisica(x):\n",
    "    if x >= limite_AB: return 'Zona A (Orilla)'\n",
    "    elif x >= limite_BC: return 'Zona B (Media)'\n",
    "    else: return 'Zona C (Duna)'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 52,
   "id": "23b4c469-d133-47bd-9314-23e6de0edfbe",
