   "source": [
    "def gdm_to_dd(coord_str):\n",
    "    import re\n",
    "    # Extraer números usando regex\n",
    "    parts = re.findall(r\"[-+]?\\d*\\.\\d+|\\d+\", coord_str)\n",
    "    if len(parts) < 4: return None, None\n",
    "    \n",
    "    # Latitud: Grados + (Minutos/60)\n",
    "    lat = float(parts[0]) + float(parts[1])/60\n",
    "    # Longitud: (Grados + (Minutos/60)) * -1 si es Oeste (W)\n",
    "    lon = (float(parts[2]) + float(parts[3])/60) * -1\n",
    "    return lat, lon"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "b3e5fc56-65c4-431a-9ea1-549647c2a8ad",
   "metadata": {},
   "outputs": [],
   "source": [
    "df_joined[['lat', 'lon']] = df_joined['GPS'].apply(lambda x: pd.Series(gdm_to_dd(x)))"
   ]
