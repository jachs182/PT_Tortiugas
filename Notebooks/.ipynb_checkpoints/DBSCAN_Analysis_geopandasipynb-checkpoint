   "source": [
    "def agrupar_nidos(grupo):\n",
    "    coords = grupo[['x_metros', 'y_metros']].values\n",
    "    \n",
    "    db = DBSCAN(eps=300, min_samples=10)\n",
    "    \n",
    "    grupo = grupo.copy()\n",
    "    grupo['cluster_id'] = db.fit_predict(coords)\n",
    "    \n",
    "    return grupo"
   ]
  },
