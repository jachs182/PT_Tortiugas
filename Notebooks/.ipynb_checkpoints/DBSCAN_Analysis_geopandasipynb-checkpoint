    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.cluster import DBSCAN\n",
    "import numpy as np\n",
    "from shapely.geometry import MultiPoint\n",
    "\n",
    "# --- CONFIGURACIÓN DE PARÁMETROS ---\n",
    "# Estos parámetros deben ser diferentes para 2024 por su alta densidad\n",
    "# Si mantenemos eps=300, todo el 2024 será un solo polígono amorfo.\n",
    "params_default = {'eps': 300, 'min_samples': 10}\n",
    "params_2024 = {'eps': 80, 'min_samples': 30} # eps más pequeño separa micro-colonias\n",
    "\n",
    "# Actualizar el diccionario de centroides y polígonos\n",
    "centroides = {}\n",
    "poligonos_dbscan = {}\n",
    "df_plot_result = []\n",
    "\n",
    "years = sorted(gdf_utm['year'].unique())\n",
    "\n",
    "# --- PASO 1: ANALÍTICA DIFERENCIADA ---\n",
    "for year in years:\n",
    "    grupo = gdf_utm[gdf_utm['year'] == year].copy()\n",
    "    coords = grupo[['x_metros', 'y_metros']].values\n",
    "    \n",
    "    # Elegir parámetros según el año\n",
    "    p = params_2024 if year == 2024 else params_default\n",
    "    \n",
    "    # Re-correr DBSCAN\n",
    "    db = DBSCAN(eps=p['eps'], min_samples=p['min_samples'])\n",
    "    grupo['cluster_id'] = db.fit_predict(coords)\n",
    "    \n",
    "    # Guardar datos sin ruido\n",
    "    datos_sin_ruido = grupo[grupo['cluster_id'] != -1]\n",
    "    df_plot_result.append(datos_sin_ruido)\n",
    "    \n",
    "    if datos_sin_ruido.empty:\n",
    "        continue\n",
    "\n",
    "    # 1. Encontrar el cluster más grande\n",
    "    cluster_principal_id = datos_sin_ruido['cluster_id'].value_counts().idxmax()\n",
    "    nidos_principal = datos_sin_ruido[datos_sin_ruido['cluster_id'] == cluster_principal_id]\n",
    "\n",
    "    # 2. Re-calcular Centroide\n",
    "    centroide = MultiPoint(nidos_principal.geometry.values).centroid\n",
    "    centroides[year] = {'x': centroide.x, 'y': centroide.y}\n",
    "\n",
    "    # 3. Re-calcular Polígono\n",
    "    poligonos_dbscan[year] = MultiPoint(nidos_principal.geometry.values).convex_hull\n",
    "\n",
    "df_plot = pd.concat(df_plot_result, ignore_index=True)\n",
    "\n",
    "# --- PASO 2: VISUALIZACIÓN DIFERENCIADA ---\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "cols = 2\n",
    "rows = (len(years) + 1) // cols\n",
    "fig, axes = plt.subplots(rows, cols, figsize=(14, 6 * rows), constrained_layout=True)\n",
    "axes = axes.flatten()\n",
    "\n",
    "# Paleta global (con viridis para mejor distinción)\n",
    "palette = dict(zip(years, sns.color_palette(\"viridis\", len(years))))\n",
    "\n",
    "for i, year in enumerate(years):\n",
    "    ax = axes[i]\n",
    "    df_year = df_plot[df_plot['year'] == year]\n",
    "    \n",
    "    if df_year.empty:\n",
    "        ax.set_title(f\"{year} - Sin Clusters\")\n",
    "        continue\n",
    "\n",
    "    # --- Zonas de fondo ---\n",
    "    ax.axvspan(limite_AB, x_max, color='lightblue', alpha=0.1)\n",
    "    ax.axvspan(limite_BC, limite_AB, color='khaki', alpha=0.1)\n",
    "    ax.axvspan(x_min, limite_BC, color='lightgreen', alpha=0.1)\n",
    "    ax.tick_params(axis='x', rotation=45)\n",
    "\n",
    "    # ==========================================\n",
    "    # 🔥 AJUSTE ESPECÍFICO PARA 2024\n",
    "    # ==========================================\n",
    "    if year == 2024:\n",
    "        scatter_size = 8    # Muy pequeño\n",
    "        scatter_alpha = 0.4  # Muy transparente para ver la superposición\n",
    "        poly_alpha = 0.1     # Menor opacidad en el relleno\n",
    "    else:\n",
    "        scatter_size = 60   # Tamaño normal\n",
    "        scatter_alpha = 0.8  # Normal\n",
    "        poly_alpha = 0.2     # Normal\n",
    "\n",
    "    # --- Polígono ---\n",
    "    if year in poligonos_dbscan and not poligonos_dbscan[year].is_empty:\n",
    "        poly = poligonos_dbscan[year]\n",
    "        if poly.geom_type == 'Polygon': # Asegurar que sea polígono, no línea\n",
    "            x_p, y_p = poly.exterior.xy\n",
    "            ax.fill(x_p, y_p, color=palette[year], alpha=poly_alpha, zorder=2)\n",
    "            ax.plot(x_p, y_p, color=palette[year], lw=2, zorder=4, label='Área Núcleo')\n",
    "\n",
    "    # --- PUNTOS (CON PARÁMETROS DIFERENCIADOS) ---\n",
    "    sns.scatterplot(\n",
    "        data=df_year, x='x_metros', y='y_metros', \n",
    "        color=palette[year], s=scatter_size, alpha=scatter_alpha,\n",
    "        edgecolor='black' if year != 2024 else 'none', # Quitar borde en 2024\n",
    "        ax=ax, zorder=3\n",
    "    )\n",
    "\n",
    "    # --- Centroide ---\n",
    "    if year in centroides:\n",
    "        ax.scatter(\n",
    "            centroides[year]['x'], centroides[year]['y'],\n",
    "            marker='*', s=300, color='red', edgecolor='black', zorder=5, label='Centroide'\n",
    "        )\n",
    "\n",
    "    # --- Zoom Individual ---\n",
    "    pad = 50\n",
    "    ax.set_xlim(df_year['x_metros'].min() - pad, df_year['x_metros'].max() + pad)\n",
    "    ax.set_ylim(df_year['y_metros'].min() - pad, df_year['y_metros'].max() + pad)\n",
    "    ax.set_aspect('equal')\n",
    "    ax.set_title(f\"Temporada {year} ({len(df_year)} nidos detectados)\", weight='bold')\n",
    "\n",
    "for j in range(len(years), len(axes)):\n",
    "    fig.delaxes(axes[j])\n",
    "\n",
    "plt.suptitle(\"Análisis Espacial Detallado de Nidos: Ajuste por Densidad\", fontsize=16, weight='bold')\n",
    "plt.show()"
   ]
